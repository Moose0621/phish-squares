generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(uuid())
  username     String       @unique
  passwordHash String       @map("password_hash")
  isAdmin      Boolean      @default(false) @map("is_admin")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  hostedGames  Game[]       @relation("GameHost")
  gamePlayers  GamePlayer[]
  picks        Pick[]
  hostedRuns   Run[]        @relation("RunHost")
  runPlayers   RunPlayer[]
  stats        UserStats?

  @@map("users")
}

model Game {
  id               String       @id @default(uuid())
  hostUserId       String       @map("host_user_id")
  host             User         @relation("GameHost", fields: [hostUserId], references: [id])
  showDate         DateTime     @map("show_date") @db.Date
  showVenue        String       @map("show_venue")
  status           GameStatus   @default(LOBBY)
  inviteCode       String       @unique @map("invite_code")
  draftOrder       String[]     @map("draft_order")
  currentRound     Int          @default(0) @map("current_round")
  currentPickIndex Int          @default(0) @map("current_pick_index")
  totalRounds      Int          @default(11) @map("total_rounds")
  maxPlayers       Int          @default(8) @map("max_players")
  runId            String?      @map("run_id")
  run              Run?         @relation(fields: [runId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  players          GamePlayer[]
  picks            Pick[]

  @@index([inviteCode])
  @@index([hostUserId])
  @@index([status])
  @@index([runId])
  @@map("games")
}

model GamePlayer {
  id            String   @id @default(uuid())
  gameId        String   @map("game_id")
  game          Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id])
  draftPosition Int      @default(0) @map("draft_position")
  joinedAt      DateTime @default(now()) @map("joined_at")

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
  @@map("game_players")
}

model Pick {
  id        String   @id @default(uuid())
  gameId    String   @map("game_id")
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  songName  String   @map("song_name")
  round     Int
  pickOrder Int      @map("pick_order")
  isBonus   Boolean  @default(false) @map("is_bonus")
  scored    Boolean?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([gameId, round])
  @@index([gameId, userId])
  @@map("picks")
}

model Song {
  id          String  @id @default(uuid())
  name        String  @unique
  artist      String  @default("")
  timesPlayed Int     @default(0) @map("times_played")
  lastPlayed  String? @map("last_played")
  isCustom    Boolean @default(false) @map("is_custom")

  @@index([name])
  @@map("songs")
}

enum GameStatus {
  LOBBY
  DRAFTING
  LOCKED
  SCORED
}

enum RunStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}

model Run {
  id           String      @id @default(uuid())
  name         String
  venue        String
  startDate    DateTime    @map("start_date") @db.Date
  endDate      DateTime    @map("end_date") @db.Date
  hostUserId   String      @map("host_user_id")
  host         User        @relation("RunHost", fields: [hostUserId], references: [id])
  inviteCode   String      @unique @map("invite_code")
  status       RunStatus   @default(UPCOMING)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  games        Game[]
  players      RunPlayer[]

  @@index([inviteCode])
  @@index([hostUserId])
  @@map("runs")
}

model RunPlayer {
  id       String   @id @default(uuid())
  runId    String   @map("run_id")
  run      Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
  userId   String   @map("user_id")
  user     User     @relation(fields: [userId], references: [id])
  joinedAt DateTime @default(now()) @map("joined_at")

  @@unique([runId, userId])
  @@index([runId])
  @@index([userId])
  @@map("run_players")
}

model UserStats {
  id               String    @id @default(uuid())
  userId           String    @unique @map("user_id")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gamesPlayed      Int       @default(0) @map("games_played")
  gamesWon         Int       @default(0) @map("games_won")
  totalPicks       Int       @default(0) @map("total_picks")
  correctPicks     Int       @default(0) @map("correct_picks")
  totalPoints      Int       @default(0) @map("total_points")
  bonusPicks       Int       @default(0) @map("bonus_picks")
  bonusCorrect     Int       @default(0) @map("bonus_correct")
  bestGamePoints   Int       @default(0) @map("best_game_points")
  currentStreak    Int       @default(0) @map("current_streak")
  longestStreak    Int       @default(0) @map("longest_streak")
  runsParticipated Int       @default(0) @map("runs_participated")
  runsWon          Int       @default(0) @map("runs_won")
  lastPlayedAt     DateTime? @map("last_played_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("user_stats")
}
